assets/data/

# Seed source data (personal trip exports)
tripdb/seed/sources/

# Dev logs and progress tracking
docs/logs/
docs/progress/
docs/sessions/
progress.yaml

# Implementation plans (dev-only)
docs/plan/

# Prototype archive (legacy, large binaries)
docs/archive/prototype/
docs/archive/prototype_docs/

# Binary assets that shouldn't be in git
*.png
*.pdf

